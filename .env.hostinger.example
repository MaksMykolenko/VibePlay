# VibePlay — single-VPS production env (Hostinger KVM-2). EXAMPLE — no real secrets.
# DNS, domain and TLS are 100% Hostinger + Caddy.
#
#   cp .env.hostinger.example .env        # then fill the blanks (NEVER commit .env)
#   docker compose --env-file .env -f docker-compose.hostinger.yml up -d --build
#
# Generate every secret with:  openssl rand -base64 48

# ── Domains / origins ────────────────────────────────────────────────────────
# The SPA calls the API SAME-ORIGIN at https://vibeplay.games/api, so WEB_ORIGIN
# and API_ORIGIN are both the app domain (host-only cookies live here).
WEB_ORIGIN=https://vibeplay.games
API_ORIGIN=https://vibeplay.games
# Direct API endpoint (Caddy routes api.vibeplay.games → api). Not used by the SPA.
PUBLIC_API_ORIGIN=https://api.vibeplay.games
# Base domain for the isolated game host. Each version is served from its own
# origin: {versionId}--{gameId}.games.vibeplayusercontent.com
# This must not share a registrable domain with WEB_ORIGIN.
GAME_HOST_BASE_DOMAIN=games.vibeplayusercontent.com
# Email Let's Encrypt uses for expiry notices (Caddy ACME account).
ACME_EMAIL=admin@vibeplay.games

# ── Database (PostgreSQL — internal service `postgres`, no public port) ───────
# DATABASE_URL is assembled in compose:
#   postgresql://vibeplay:<POSTGRES_PASSWORD>@postgres:5432/vibeplay
POSTGRES_PASSWORD=

# ── Redis (internal service `redis`, no public port) ─────────────────────────
# REDIS_URL is fixed in compose: redis://redis:6379

# ── Storage: LOCAL MinIO in Docker (internal-only, no public port) ───────────
# These are BOTH the MinIO root credentials AND the app's S3 keys.
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
# Buckets (auto-created by the minio-init service on first `up`):
S3_QUARANTINE_BUCKET=vibeplay-quarantine
S3_PUBLISHED_BUCKET=vibeplay-published
# Private bucket for uploaded user avatars (auto-created; streamed by the API).
S3_AVATARS_BUCKET=vibeplay-avatars
# Note: the browser never hits MinIO directly — uploads go through the API
# (PUT /api/uploads/:id/direct) and published files are streamed by game-host,
# so MinIO stays internal. No public/presigned MinIO URL is exposed.

# ── Malware scanning (ClamAV — internal service `clamav`, no public port) ────
# SCAN_DRIVER=clamav is set in compose; CLAMAV_HOST=clamav, CLAMAV_PORT=3310.
# Do NOT disable scanning in production.

# ── Auth / session / CSRF / password pepper ──────────────────────────────────
# SESSION_SECRET    ≥ 32 chars  (signs sessions)
# PASSWORD_PEPPER   ≥ 16 chars  (extra secret mixed into password hashes)
# PREVIEW_URL_SECRET ≥ 32 chars (signs admin game-preview URLs)
SESSION_SECRET=
PASSWORD_PEPPER=
PREVIEW_URL_SECRET=
# Cookies are HttpOnly + Secure + SameSite=Lax, HOST-ONLY on vibeplay.games
# (never Domain=.vibeplay.games). CSRF = double-submit cookie (vp_csrf).
INVITE_ONLY=true

# ── Stripe Billing (server-only secrets) ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREATOR_PLUS_PRICE_ID=
PUBLIC_APP_URL=https://vibeplay.games

# ── Email (required in production) ───────────────────────────────────────────
# Production startup and readiness fail closed when SMTP is unavailable.
EMAIL_DRIVER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=VibePlay <no-reply@vibeplay.games>

# ── Logging / observability (optional) ───────────────────────────────────────
LOG_LEVEL=info
UPLOAD_MAX_COMPRESSED_MB=100
