{
  "name": "vibeplay-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/shared",
    "packages/config",
    "packages/database",
    "packages/storage",
    "packages/sdk",
    "apps/api",
    "apps/worker",
    "apps/game-host",
    "apps/web"
  ],
  "scripts": {
    "build:packages": "npm run build -w @vibeplay/shared -w @vibeplay/config -w @vibeplay/database -w @vibeplay/storage -w @vibeplay/sdk",
    "build:apps": "npm run build -w @vibeplay/api -w @vibeplay/worker -w @vibeplay/game-host -w @vibeplay/web",
    "build": "npm run db:generate && npm run build:packages && npm run build:apps",
    "dev:web": "npm run dev -w @vibeplay/web",
    "dev:api": "npm run dev -w @vibeplay/api",
    "dev:worker": "npm run dev -w @vibeplay/worker",
    "dev:game-host": "npm run dev -w @vibeplay/game-host",
    "db:generate": "npm run generate -w @vibeplay/database",
    "db:migrate": "npm run migrate:deploy -w @vibeplay/database",
    "db:seed": "npm run seed -w @vibeplay/database",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration -w @vibeplay/api",
    "email:test": "npm run email:test -w @vibeplay/api --",
    "test:e2e": "playwright test",
    "fixtures:build": "node fixtures/build-fixtures.mjs",
    "grant-admin": "npm run grant-admin -w @vibeplay/database",
    "build:demo": "npm run build:demo -w @vibeplay/web"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.12.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "tsx": "^4.20.0"
  }
}
