{
  "name": "@vibeplay/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "build": "npm run generate && tsc -b",
    "typecheck": "npm run generate && tsc --noEmit",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:diff": "prisma migrate diff --from-migrations prisma/migrations --to-schema prisma/schema.prisma --script",
    "seed": "tsx src/seed.ts",
    "grant-admin": "tsx src/grant-admin.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vibeplay/shared": "*",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.0",
    "argon2": "^0.44.0",
    "prisma": "^7.8.0",
    "tsx": "^4.20.0"
  }
}
