generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------

enum UserRole {
  PLAYER
  CREATOR
  ADMIN
  // Platform founder. Superset of ADMIN; uniquely allowed to moderate (approve/
  // reject) their OWN game versions for solo/beta testing — but only versions
  // that already passed validation + malware scan (READY_FOR_REVIEW).
  OWNER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  username          String     @unique
  displayName       String
  passwordHash      String
  avatarUrl         String?
  /// Object-storage key for an uploaded avatar (private avatars bucket). When
  /// set, avatarUrl points at GET /api/users/:id/avatar which streams this key.
  /// Null when the user has no uploaded avatar (external avatarUrl or none).
  avatarObjectKey   String?
  bio               String     @default("")
  role              UserRole   @default(PLAYER)
  status            UserStatus @default(ACTIVE)
  statusReason      String?
  emailVerifiedAt   DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  lastLoginAt       DateTime?
  /// Persisted notification preferences (validated by notificationPrefsSchema).
  notificationPrefs Json       @default("{}")
  stripeCustomerId  String?    @unique

  sessions                Session[]
  oauthAccounts           OAuthAccount[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  invitesCreated          Invite[]                 @relation("InviteCreatedBy")
  games                   Game[]
  likes                   Like[]
  favorites               Favorite[]
  playSessions            PlaySession[]
  comments                Comment[]
  reports                 Report[]                 @relation("ReportReporter")
  assignedReports         Report[]                 @relation("ReportAssignee")
  notifications           Notification[]
  moderationDecisions     ModerationDecision[]
  auditLogs               AuditLog[]
  feedback                Feedback[]               @relation("FeedbackAuthor")
  feedbackResolved        Feedback[]               @relation("FeedbackResolvedBy")
  subscription            Subscription?
  gameSaves               GameSave[]
  analyticsEvents         AnalyticsEvent[]
  hostedRooms             GameRoom[]               @relation("GameRoomHostUser")
  roomPlayers             GameRoomPlayer[]

  @@index([status])
  @@index([role])
}

enum SubscriptionPlan {
  CREATOR_PLUS
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             String             @default("stripe")
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  plan                 SubscriptionPlan   @default(CREATOR_PLUS)
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status, currentPeriodEnd])
  @@index([stripeCustomerId])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([processedAt])
}

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@unique([provider, userId])
  @@index([userId])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  csrfHash  String
  ipHash    String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Invite {
  id          String    @id @default(cuid())
  codeHash    String    @unique
  email       String?
  role        UserRole  @default(PLAYER)
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  createdById String?
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([email])
}

// ---------------------------------------------------------------------------
// Games & versions
// ---------------------------------------------------------------------------

enum GameStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  HIDDEN
  SUSPENDED
}

enum GameVersionStatus {
  UPLOADING
  QUARANTINED
  VALIDATING
  SCAN_FAILED
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum AgeRating {
  EVERYONE
  TEEN
  MATURE
}

enum AiDisclosure {
  NONE
  ASSISTED
  GENERATED
}

enum FeaturedCategory {
  HERO
  TRENDING
  EDITORS_CHOICE
}

model Game {
  id                    String               @id @default(cuid())
  slug                  String               @unique
  creatorId             String
  creator               User                 @relation(fields: [creatorId], references: [id], onDelete: Restrict)
  title                 String
  shortDescription      String
  description           String
  category              String
  ageRating             AgeRating            @default(EVERYONE)
  status                GameStatus           @default(DRAFT)
  tags                  String[]             @default([])
  devices               String[]             @default(["desktop"])
  controls              Json                 @default("[]")
  toolsUsed             String[]             @default([])
  multiplayer           Boolean              @default(false)
  // VibePlay-owned multiplayer metadata (spec Phase 5). `multiplayer` above stays
  // as the catalog/browse flag; these describe HOW multiplayer works for the game.
  multiplayerEnabled    Boolean              @default(false)
  multiplayerMaxPlayers Int                  @default(8)
  multiplayerTransport  MultiplayerTransport @default(NONE)
  /// External realtime server base URL (wss:// in production). Null for NONE /
  /// VIBEPLAY_SDK transports. Validated before persistence; never points at MinIO.
  multiplayerWsUrl      String?
  /// Optional list of supported modes, e.g. ["free_for_all","teams"]. Validated JSON.
  multiplayerModes      Json                 @default("[]")
  aiDisclosure          AiDisclosure         @default(NONE)
  featuredCategory      FeaturedCategory?
  coverUrl              String?
  /// Private object-storage key for a creator-uploaded raster cover. The public
  /// coverUrl points to the API streaming endpoint; object storage stays private.
  coverObjectKey        String?
  publishedVersionId    String?              @unique
  publishedVersion      GameVersion?         @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  publishedAt           DateTime?
  likesCount            Int                  @default(0)
  playsCount            Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  versions        GameVersion[]    @relation("GameVersions")
  screenshots     GameScreenshot[]
  likes           Like[]
  favorites       Favorite[]
  playSessions    PlaySession[]
  comments        Comment[]
  gameSaves       GameSave[]
  analyticsEvents AnalyticsEvent[]
  rooms           GameRoom[]

  @@index([status, category])
  @@index([creatorId])
  @@index([status, publishedAt])
  @@index([featuredCategory])
}

model GameVersion {
  id                    String            @id @default(cuid())
  gameId                String
  game                  Game              @relation("GameVersions", fields: [gameId], references: [id], onDelete: Cascade)
  version               String
  status                GameVersionStatus @default(UPLOADING)
  quarantineObjectKey   String?
  publishedObjectPrefix String?
  compressedSize        BigInt?
  uncompressedSize      BigInt?
  fileCount             Int?
  entrypoint            String?
  contentHash           String?
  declaredSha256        String?
  aiDisclosure          AiDisclosure      @default(NONE)
  toolsUsed             String[]          @default([])
  changelog             String            @default("")
  validationReport      Json?
  rejectReason          String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  publishedOf         Game?                @relation("PublishedVersion")
  moderationDecisions ModerationDecision[]
  playSessions        PlaySession[]
  upload              Upload?
  analyticsEvents     AnalyticsEvent[]
  rooms               GameRoom[]           @relation("GameRoomVersion")

  @@unique([gameId, version])
  @@index([status, submittedAt])
  @@index([gameId, createdAt])
}

/// Tracks a single presigned-upload lifecycle for a GameVersion (one-time completion).
model Upload {
  id             String      @id @default(cuid())
  gameVersionId  String      @unique
  gameVersion    GameVersion @relation(fields: [gameVersionId], references: [id], onDelete: Cascade)
  objectKey      String
  declaredSize   BigInt
  declaredSha256 String
  fileName       String
  completedAt    DateTime?
  abandonedAt    DateTime?
  createdAt      DateTime    @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

enum ModerationDecisionType {
  APPROVE
  REJECT
}

/// Immutable moderation decision record — never updated, never deleted.
model ModerationDecision {
  id            String                 @id @default(cuid())
  gameVersionId String
  gameVersion   GameVersion            @relation(fields: [gameVersionId], references: [id], onDelete: Cascade)
  moderatorId   String?
  moderator     User?                  @relation(fields: [moderatorId], references: [id], onDelete: SetNull)
  decision      ModerationDecisionType
  reason        String                 @default("")
  notes         String                 @default("")
  createdAt     DateTime               @default(now())

  @@index([gameVersionId])
}

model GameScreenshot {
  id        String @id @default(cuid())
  gameId    String
  game      Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int    @default(0)

  @@index([gameId, sortOrder])
}

// ---------------------------------------------------------------------------
// Social
// ---------------------------------------------------------------------------

model Like {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, gameId])
  @@index([gameId])
}

model Favorite {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, gameId])
  @@index([gameId])
}

model PlaySession {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  gameId          String
  game            Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameVersionId   String
  gameVersion     GameVersion @relation(fields: [gameVersionId], references: [id], onDelete: Cascade)
  startedAt       DateTime    @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  clientSessionId String?

  @@index([gameId, startedAt])
  @@index([userId, startedAt])
}

/// Privacy-safe, allowlisted first-party analytics. The API derives actor/source/time,
/// verifies launch context, and stores only bounded metadata defined in shared schemas.
model AnalyticsEvent {
  id        String       @id @default(cuid())
  type      String
  gameId    String
  game      Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  versionId String?
  version   GameVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType String
  source    String
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())

  @@index([gameId, createdAt])
  @@index([versionId, createdAt])
  @@index([type, createdAt])
  @@index([userId, createdAt])
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

model Comment {
  id        String        @id @default(cuid())
  gameId    String
  game      Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  status    CommentStatus @default(VISIBLE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([gameId, status, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Cloud saves
// ---------------------------------------------------------------------------

/// Per-user, per-game cloud save (spec: cloud saves as a reason to register).
/// Stores ONLY validated JSON game state — never code, never secrets. Keyed to
/// the GAME (not a specific version) so progress survives version updates. One
/// row per (user, game); writes upsert. The API enforces JSON shape, max depth,
/// and a hard size limit before anything is persisted. Cascades on both user
/// and game deletion (matches Like/Favorite), so saves never outlive either.
model GameSave {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  /// Arbitrary game state, validated as safe JSON by the API before storage.
  data          Json
  /// Game-defined save format version (lets a game migrate old saves).
  schemaVersion Int      @default(1)
  /// Byte length of the canonical JSON, recorded for quotas/observability.
  sizeBytes     Int
  /// SHA-256 of the canonical JSON; lets clients skip redundant writes.
  dataHash      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId, updatedAt])
}

// ---------------------------------------------------------------------------
// Safety
// ---------------------------------------------------------------------------

enum ReportTargetType {
  GAME
  COMMENT
  USER
}

enum ReportReason {
  MALICIOUS_BEHAVIOR
  COPYRIGHT
  STOLEN_CONTENT
  ADULT_CONTENT
  HATE
  HARASSMENT
  SPAM
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

model Report {
  id              String           @id @default(cuid())
  reporterId      String?
  reporter        User?            @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  targetType      ReportTargetType
  targetId        String
  reason          ReportReason
  details         String           @default("")
  status          ReportStatus     @default(OPEN)
  resolutionNote  String           @default("")
  assignedAdminId String?
  assignedAdmin   User?            @relation("ReportAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  resolvedAt      DateTime?

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

enum NotificationType {
  EMAIL_VERIFIED
  GAME_VALIDATION_FAILED
  GAME_READY_FOR_REVIEW
  GAME_APPROVED
  GAME_REJECTED
  NEW_COMMENT
  REPORT_RESOLVED
  ACCOUNT_SUSPENDED
  PLATFORM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  metadata  Json             @default("{}")
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

/// Append-only at the application level: the API exposes create + read only.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String
  metadata   Json     @default("{}")
  ipHash     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

/// Beta feedback and bug reports (spec §38).
enum FeedbackCategory {
  FEEDBACK
  BUG
}

enum FeedbackStatus {
  OPEN
  RESOLVED
}

model Feedback {
  id           String           @id @default(cuid())
  userId       String?
  category     FeedbackCategory
  status       FeedbackStatus   @default(OPEN)
  message      String
  page         String           @default("")
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime         @default(now())

  user       User? @relation("FeedbackAuthor", fields: [userId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("FeedbackResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([resolvedById])
}

// ---------------------------------------------------------------------------
// Multiplayer rooms (VibePlay-owned). VibePlay owns room lifecycle, identity, and
// the short join code; the game's external realtime server (e.g. the Boxy Tanks
// WebSocket server) owns the live simulation, keyed by the VibePlay roomCode. Auth
// never enters the game iframe — the game receives a short-lived signed room token.
// ---------------------------------------------------------------------------

enum GameRoomStatus {
  WAITING
  ACTIVE
  FINISHED
  EXPIRED
}

enum GameRoomVisibility {
  PRIVATE
  PUBLIC
}

enum GameRoomPlayerStatus {
  JOINED
  LEFT
  KICKED
}

/// How a game's realtime multiplayer is transported.
/// - NONE: no multiplayer.
/// - EXTERNAL_WS: game ships its own WebSocket server (Boxy Tanks model).
/// - VIBEPLAY_SDK: realtime relayed over the VibePlay SDK bridge (future).
enum MultiplayerTransport {
  NONE
  EXTERNAL_WS
  VIBEPLAY_SDK
}

/// Anonymous, cookie-scoped guest identity. Lets a not-logged-in player create,
/// host, and rejoin multiplayer rooms without an account. The raw cookie token is
/// NEVER stored — only its HMAC hash (mirrors Session). Holds no PII beyond an
/// optional display name the guest chose for a room.
model Guest {
  id          String   @id @default(cuid())
  /// HMAC-SHA256 of the opaque guest cookie token (never store the raw token).
  tokenHash   String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  hostedRooms GameRoom[]       @relation("GameRoomHostGuest")
  roomPlayers GameRoomPlayer[]

  @@index([lastSeenAt])
}

model GameRoom {
  id          String             @id @default(cuid())
  gameId      String
  game        Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  versionId   String?
  version     GameVersion?       @relation("GameRoomVersion", fields: [versionId], references: [id], onDelete: SetNull)
  /// Short, human-typable join code (unique). 4-6 chars, ambiguity-free alphabet.
  roomCode    String             @unique
  status      GameRoomStatus     @default(WAITING)
  visibility  GameRoomVisibility @default(PRIVATE)
  /// Exactly one of hostUserId / hostGuestId is set at a time. Host can transfer.
  hostUserId  String?
  hostUser    User?              @relation("GameRoomHostUser", fields: [hostUserId], references: [id], onDelete: SetNull)
  hostGuestId String?
  hostGuest   Guest?             @relation("GameRoomHostGuest", fields: [hostGuestId], references: [id], onDelete: SetNull)
  maxPlayers  Int                @default(8)
  /// Denormalized count of JOINED players, kept in sync inside transactions.
  playerCount Int                @default(0)
  mode        String             @default("free_for_all")
  /// Mirrors MultiplayerTransport as a stable string for the room token payload.
  transport   String             @default("external_ws")
  /// Realtime server URL handed to the game via the room token (wss:// in prod).
  wsUrl       String?
  expiresAt   DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  players GameRoomPlayer[]

  @@index([gameId, status])
  @@index([status, expiresAt])
}

model GameRoomPlayer {
  id          String               @id @default(cuid())
  roomId      String
  room        GameRoom             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// Exactly one of userId / guestId identifies the player. Null user + null guest
  /// is never written. Unique-per-room (below) prevents duplicate membership rows.
  userId      String?
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestId     String?
  guest       Guest?               @relation(fields: [guestId], references: [id], onDelete: SetNull)
  displayName String
  avatarUrl   String?
  isHost      Boolean              @default(false)
  status      GameRoomPlayerStatus @default(JOINED)
  joinedAt    DateTime             @default(now())
  leftAt      DateTime?

  // Postgres treats NULLs as distinct, so these uniques bind only real ids: a
  // user (or guest) can hold at most one membership row per room; rejoin updates
  // the existing row rather than inserting a duplicate.
  @@unique([roomId, userId])
  @@unique([roomId, guestId])
  @@index([roomId, status])
}
