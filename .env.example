# VibePlay environment configuration (example — no real secrets here).
# Copy to .env and fill in values. The API refuses to start with missing critical config.

NODE_ENV=development

# ---------------------------------------------------------------------------
# Origins. The game origin MUST be a different registrable domain than the
# web/app origin in production. Auth cookies are host-only on the API/app
# origin and must never cover the game origin.
#
# GAME_ORIGIN is the BASE of the game host. Every published version is served
# from its own subdomain origin:
#     {versionId}--{gameId}.games.localhost:8080                    (local)
#     {versionId}--{gameId}.games-beta.vibeplayusercontent.example  (staging)
# Browsers resolve any *.localhost name (including nested subdomains) to
# 127.0.0.1, so the wildcard scheme works locally without DNS setup. For
# curl/Node use --resolve or lvh.me / localtest.me equivalents — see
# docs/GAME_SANDBOX.md.
# ---------------------------------------------------------------------------
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3000
GAME_ORIGIN=http://games.localhost:8080
# CSP source used by the web container. Keep the wildcard and match the
# browser-visible scheme/port from GAME_ORIGIN.
GAME_FRAME_SRC=http://*.games.localhost:8080

API_PORT=3000
GAME_HOST_PORT=8080

# ---------------------------------------------------------------------------
# Database / queue
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://vibeplay:vibeplay@localhost:5432/vibeplay
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Secrets — generate long random values, e.g.: openssl rand -base64 48
# ---------------------------------------------------------------------------
SESSION_SECRET=
PASSWORD_PEPPER=
# Used to sign short-lived admin preview URLs for the game host:
PREVIEW_URL_SECRET=

# Google OAuth (backend authorization-code flow; never expose the secret to Vite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://vibeplay.games/api/auth/google/callback

SESSION_TTL_HOURS=336

# ---------------------------------------------------------------------------
# Object storage (S3-compatible: MinIO locally; R2/S3/B2 in production).
# STORAGE_DRIVER=s3 in real deployments; "fs" exists for tests/dev only.
# ---------------------------------------------------------------------------
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=vibeplay
S3_SECRET_ACCESS_KEY=vibeplay-minio-secret
S3_QUARANTINE_BUCKET=vibeplay-quarantine
S3_PUBLISHED_BUCKET=vibeplay-published
S3_AVATARS_BUCKET=vibeplay-avatars
S3_FORCE_PATH_STYLE=true
# Public presigned-upload endpoint as seen from the browser (defaults to S3_ENDPOINT):
S3_PUBLIC_ENDPOINT=http://localhost:9000
# Only used when STORAGE_DRIVER=fs:
FS_STORAGE_ROOT=.data/storage

# ---------------------------------------------------------------------------
# Malware scanning. SCAN_DRIVER=clamav is required in production;
# "off" is allowed only in development/test and is recorded in the scan report.
# ---------------------------------------------------------------------------
SCAN_DRIVER=clamav
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ---------------------------------------------------------------------------
# Email (Mailpit locally: SMTP on 1025, UI on http://localhost:8025)
# ---------------------------------------------------------------------------
EMAIL_DRIVER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="VibePlay <no-reply@vibeplay.local>"

# ---------------------------------------------------------------------------
# Upload limits (worker re-validates everything server-side)
# ---------------------------------------------------------------------------
UPLOAD_MAX_COMPRESSED_MB=50
UPLOAD_MAX_UNCOMPRESSED_MB=250
UPLOAD_MAX_FILES=5000
UPLOAD_MAX_SINGLE_FILE_MB=100

# ---------------------------------------------------------------------------
# Beta access
# ---------------------------------------------------------------------------
INVITE_ONLY=true

# Optional monitoring (app must run without it)
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Frontend build-time variables (Vite). VITE_APP_MODE=real talks to the API;
# VITE_APP_MODE=demo is the GitHub Pages localStorage demo with a banner.
# ---------------------------------------------------------------------------
VITE_APP_MODE=real
VITE_API_URL=http://localhost:3000/api
VITE_GAME_ORIGIN=http://games.localhost:8080
VITE_ENABLE_DEMO_ROLES=false
